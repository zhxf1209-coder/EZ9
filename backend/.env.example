# ============================================
# Backend Environment Variables (.env.example)
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# MiniMax AI API Key (for AI-powered fortune analysis)
# Get your API key from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key-here

# Optional: API Key for MiniMax (alternative)
MINIMAX_API_KEY_ALT=your-alternative-minimax-api-key

# CORS Configuration (comma-separated origins for production)
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://bazi.example.com
ALLOWED_ORIGINS=
